# Domyślnie (bez tego pliku) edytor zapisuje dokumenty na dysk, do content/ storefrontu demo —
# round-trip działa lokalnie bez żadnej konfiguracji.
#
# Poniższe przełącza edytor w tryb produkcyjny „własne repo": zapis = commit do repo sklepu,
# a deploy Vercela, który po nim leci, jest publikacją. Zmiana wyłącznie konfiguracji —
# żadnego kodu edytora to nie dotyka (patrz apps/editor/src/lib/pages.ts).

# GITHUB_CONTENT_OWNER=pawelekbyra
# GITHUB_CONTENT_REPO=nazwa-repo-sklepu
# Fine-grained token z uprawnieniem Contents: read+write TYLKO na to jedno repo.
# GITHUB_CONTENT_TOKEN=github_pat_...
# GITHUB_CONTENT_BRANCH=main
# GITHUB_CONTENT_DIR=content

# Który sklep/stronę edytujemy (domyślnie demo-store / page_home)
# EDITOR_STORE_ID=demo-store
# EDITOR_PAGE_ID=page_home
